# =============================================================================
# HCD Title Transfer Agent — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# GitHub token for Copilot CLI authentication (required for agent operations)
# Obtain from: https://github.com/settings/tokens
GH_TOKEN=
COPILOT_GITHUB_TOKEN=

# GitHub username for quota API lookups (optional — auto-detected from token)
GITHUB_USERNAME=
